<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hrms_attendance_list" model="ir.ui.view">
        <field name="name">hrms.attendance.list</field>
        <field name="model">hrms.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="work_hours" sum="Total Hours"/>
                <field name="extra_hours" sum="Total Extra"/>
            </list>
        </field>
    </record>

    <record id="view_hrms_attendance_search" model="ir.ui.view">
        <field name="name">hrms.attendance.search</field>
        <field name="model">hrms.attendance</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="date"/>
                <filter string="Today" name="today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_emp" context="{'group_by':'employee_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hrms_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">hrms.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hrms_attendance_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>
</odoo>