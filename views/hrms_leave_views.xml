<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hrms_leave_list" model="ir.ui.view">
        <field name="name">hrms.leave.list</field>
        <field name="model">hrms.leave</field>
        <field name="arch" type="xml">
            <list string="Time Off" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'" decoration-muted="state == 'draft'">
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="leave_type"/>
                <field name="number_of_days"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hrms_leave_form" model="ir.ui.view">
        <field name="name">hrms.leave.form</field>
        <field name="model">hrms.leave</field>
        <field name="arch" type="xml">
            <form string="Time Off Request">
                <header>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="custom_hrms.group_hrms_admin"/>
                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary" invisible="state != 'draft'"
                            groups="custom_hrms.group_hrms_admin"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="leave_type"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="number_of_days" readonly="1"/>
                        </group>
                        <group>
                            <field name="reason"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" invisible="1"/>
                            <field name="approved_by" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hrms_leave_search" model="ir.ui.view">
        <field name="name">hrms.leave.search</field>
        <field name="model">hrms.leave</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <filter string="Pending" name="pending" domain="[('state','=','draft')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_emp" context="{'group_by':'employee_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by':'leave_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hrms_leave" model="ir.actions.act_window">
        <field name="name">Time Off</field>
        <field name="res_model">hrms.leave</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hrms_leave_search"/>
    </record>
</odoo>